# Supabase (optional — leave unset to use local-only demo mode)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# GamePlan schedule pipeline (optional)
# Remote JSON in same shape as lib/data-sources/schedule/ingest-default.json
# GAMEPLAN_SCHEDULE_SOURCE_URL=
# Remote fetch TTL (ms); used by fetch-schedule + POST /api/gameplan/schedule
# GAMEPLAN_SCHEDULE_CACHE_TTL_MS=900000
# Staleness hint for getDataFreshness().isStale vs ingest _meta.lastUpdated
# GAMEPLAN_SCHEDULE_STALE_AFTER_MS=86400000
# Optional secret for POST /api/gameplan/schedule body { "secret": "..." }
# GAMEPLAN_PIPELINE_CRON_SECRET=

# Writable path for last-known-good validated schedule JSON (default: .gameplan/schedule-lkg.json under cwd)
# GAMEPLAN_SCHEDULE_LKG_PATH=

# When "1", Settings shows a collapsible pipeline status panel (fetches GET /api/gameplan/schedule)
# NEXT_PUBLIC_GAMEPLAN_PIPELINE_DEBUG=1
